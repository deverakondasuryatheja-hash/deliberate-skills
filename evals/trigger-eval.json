      "category": "implicit_plan",
      "notes": "'think through' = planning signal"
    },
    {
      "id": 4,
      "prompt": "design the approach for real-time notifications",
      "expected_skill": "deliberate-plan",
      "category": "explicit_plan",
      "notes": "'design the approach' = explicit trigger"
    },
    {
      "id": 5,
      "prompt": "I need a deep plan for the payment integration",
      "expected_skill": "deliberate-plan",
      "category": "explicit_plan",
      "notes": "'deep plan' = explicit trigger"
    },
    {
      "id": 6,
      "prompt": "create a plan for adding search functionality with pgvector",
